@font-face {
  font-family: '{{fontName}}';
  font-style: normal;
  font-weight: 400;
  font-display: swap;
   src: url('{{basePath}}{{fontName}}.woff2') format('woff2');
}

.{{baseClass}} {
    font-family: "{{fontName}}";
    font-style: normal;
    font-weight: normal;
    font-variant: normal;
    text-transform: none;
    line-height: 1;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
}

{{#each codepoints}}
.{{../classPrefix}}-{{@key}}:before {
    content: "\\{{this}}";
}
{{/each}}
